/* ---------- render week ---------- */
let shownWeek = weekNum;
function renderWeek(n){
  shownWeek = n;
  const w = WEEKS[n-1];
  document.getElementById('wk-num').textContent = 'Semaine '+n+' / 13';
  document.getElementById('wk-title').textContent = w.t;
  document.getElementById('wk-why').textContent = w.w;
  document.getElementById('week-range').textContent = w.r;
  const box = document.getElementById('wk-actions');
  box.innerHTML='';
  w.a.forEach((txt,i)=>{
    const key='w'+n+'a'+i;
    const row=document.createElement('div');
    row.className='check'+(store.get(key)==='1'?' done':'');
    row.innerHTML='<div class="box">'+(store.get(key)==='1'?'✓':'')+'</div><div class="txt">'+txt+'</div>';
    row.onclick=()=>{
      const done = row.classList.toggle('done');
      store.set(key,done?'1':'0');
      row.querySelector('.box').textContent = done?'✓':'';
    };
    box.appendChild(row);
  });
  document.getElementById('prev-wk').disabled = n<=1;
  document.getElementById('next-wk').disabled = n>=13;
  document.getElementById('today-week-mission').textContent =
    'S'+weekNum+' — '+WEEKS[weekNum-1].t+' ('+WEEKS[weekNum-1].r+')';
}
document.getElementById('prev-wk').onclick=()=>renderWeek(shownWeek-1);
document.getElementById('next-wk').onclick=()=>renderWeek(shownWeek+1);
document.getElementById('now-wk').onclick=()=>renderWeek(weekNum);
renderWeek(weekNum);

/* ---------- render rituals (per-day persistence) ---------- */
const rBox = document.getElementById('rituals');
function ritualCount(){
  return RITUALS.reduce((s,_,i)=>s+(store.get('r-'+dateKey+'-'+i)==='1'?1:0),0);
}
function updateStreakLine(){
  document.getElementById('streak').textContent = ritualCount()+' / '+RITUALS.length+' rituels faits aujourd\u2019hui';
}
RITUALS.forEach((r,i)=>{
  const key='r-'+dateKey+'-'+i;
  const row=document.createElement('div');
  row.className='check'+(store.get(key)==='1'?' done':'');
  row.innerHTML='<div class="box">'+(store.get(key)==='1'?'✓':'')+'</div><div class="txt">'+r.t+'</div>';
  row.onclick=()=>{
    const done=row.classList.toggle('done');
    store.set(key,done?'1':'0');
    row.querySelector('.box').textContent=done?'✓':'';
    updateStreakLine();
  };
  rBox.appendChild(row);
});
updateStreakLine();
</script>
